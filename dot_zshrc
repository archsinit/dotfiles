# PATH
export PATH="$HOME/.local/bin:$PATH"

# nvm
export NVM_DIR="$HOME/.nvm"
[ -s "$(brew --prefix)/opt/nvm/nvm.sh" ] && \. "$(brew --prefix)/opt/nvm/nvm.sh"
[ -s "$(brew --prefix)/opt/nvm/etc/bash_completion.d/nvm" ] && \. "$(brew --prefix)/opt/nvm/etc/bash_completion.d/nvm"

# Sync dotfiles: apply, commit, and push to remote.
# Usage: dotpush [commit message]
dotpush() {
  local msg="${1:-update dotfiles $(date +%Y-%m-%d)}"
  local src
  src="$(chezmoi source-path)"

  chezmoi apply || return 1
  git -C "$src" add -A
  git -C "$src" diff --cached --quiet && echo "nothing to commit" && return 0
  git -C "$src" commit -m "$msg"
  git -C "$src" push
}

# Set up dev panes in the current tmux window.
# Usage: dev [project-dir]  (defaults to ~/Developer)
dev() {
  local project_dir="${1:-$HOME/Developer}"

  if [ -z "$TMUX" ]; then
    echo "dev: must be run from inside a tmux session"
    return 1
  fi

  tmux rename-window "dev"
  tmux send-keys "cd \"$project_dir\" && nvim" C-m

  tmux split-window -h -p 50 -c "$project_dir"
  tmux send-keys "cd \"$project_dir\" && codex" C-m

  tmux split-window -v -p 50 -c "$project_dir"
  tmux send-keys "cd \"$project_dir\" && claude" C-m

  tmux select-pane -t 1
}

# Auto-start tmux when opening a new terminal window.
if [ -z "$TMUX" ]; then
  exec tmux new-session
fi

[ -f ~/.fzf.zsh ] && source ~/.fzf.zsh

# ── Notes ─────────────────────────────────────────────────────────────
export NOTES="$HOME/Documents/notes"

# Go to notes folder instantly
alias n="cd $NOTES"

# Open a specific note by fuzzy search
nf() {
  local file
  file=$(find "$NOTES" -type f -name "*.md" | fzf --preview 'cat {}')
  [[ -n "$file" ]] && nvim "$file"
}

# Create a new dated journal entry and open it
nj() {
  local date=$(date +%Y-%m-%d)
  local file="$NOTES/journals/${date}.md"
  mkdir -p "$NOTES/journals"
  [[ ! -f "$file" ]] && echo "# ${date}" > "$file"
  nvim "$file"
}

# Quick inbox capture — write a thought without opening an editor
ni() {
  local date=$(date +%Y-%m-%d\ %H:%M)
  echo "- [${date}] $*" >> "$NOTES/inbox/capture.md"
  echo "captured."
}

# Search inside all notes by content
ns() {
  rg --type md "$*" "$NOTES" | fzf
}

# Git commit everything with a message
nc() {
  cd "$NOTES" && git add . && git commit -m "$*"
}

# Push to VPS
np() {
  cd "$NOTES" && git push
}

# Git status shortcut
nst() {
  cd "$NOTES" && git status
}

# Log shortcut
nl() {
  cd "$NOTES" && git log --oneline --graph
}
