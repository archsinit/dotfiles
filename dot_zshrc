# PATH
export PATH="$HOME/.local/bin:$PATH"

# nvm
export NVM_DIR="$HOME/.nvm"
[ -s "$(brew --prefix)/opt/nvm/nvm.sh" ] && \. "$(brew --prefix)/opt/nvm/nvm.sh"
[ -s "$(brew --prefix)/opt/nvm/etc/bash_completion.d/nvm" ] && \. "$(brew --prefix)/opt/nvm/etc/bash_completion.d/nvm"

# Sync dotfiles: apply, commit, and push to remote.
# Usage: dotpush [commit message]
dotpush() {
  local msg="${1:-update dotfiles $(date +%Y-%m-%d)}"
  local src
  src="$(chezmoi source-path)"

  chezmoi apply || return 1
  git -C "$src" add -A
  git -C "$src" diff --cached --quiet && echo "nothing to commit" && return 0
  git -C "$src" commit -m "$msg"
  git -C "$src" push
}

# Open (or attach to) the dev tmux session.
# Usage: dev [project-dir]  (defaults to ~/Developer)
dev() {
  local session="dev"
  local project_dir="${1:-$HOME/Developer}"

  if ! tmux has-session -t "$session" 2>/dev/null; then
    tmux new-session -d -s "$session" -c "$project_dir" -n nvim
    tmux send-keys -t "$session:1.1" "cd \"$project_dir\" && nvim" C-m

    tmux split-window -h -p 50 -t "$session:1.1" -c "$project_dir"
    tmux send-keys -t "$session:1.2" "cd \"$project_dir\" && codex" C-m

    tmux split-window -v -p 50 -t "$session:1.2" -c "$project_dir"
    tmux send-keys -t "$session:1.3" "cd \"$project_dir\" && claude" C-m

    tmux select-pane -t "$session:1.1"
  fi

  if [ -n "$TMUX" ]; then
    tmux switch-client -t "$session"
  else
    tmux attach-session -t "$session"
  fi
}

# Auto-start tmux when opening a new terminal window.
[ -z "$TMUX" ] && dev
